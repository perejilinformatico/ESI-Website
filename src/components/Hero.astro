---
import "../styles/cartoon.css";
---

<div class="flex flex-col justify-center items-center h-screen">
    <h1 class="font-bold" style="font-family: 'Bungee', sans-serif;">ESI</h1>
    <div class="w-2/3">
        <p class="text-2xl text-center">
            Conocerte también es aprender.<br /> Explorá la ESI de forma libre y respetuosa.
        </p>
    </div>
    <div class="flex justify-center items-center m-5">
        <a class="btn btn-primary text-center" style="margin: 20px;" id="start"
            >Comenzar</a
        >
    </div>
</div>

<script lang="ts">
    const button = document.getElementById("start");
    button?.addEventListener("click", () => {
        window.location.href = "/" + "#text_info";
    });
</script>
